#!/bin/sh
# mmchong-init 本仓库用：轻量 pre-commit（无 pnpm/turbo/单测全量管道）。
# 复制到其他业务仓库时，请按目标栈恢复或增补构建、lint、测试步骤。

PROJECT_DIR=$(git rev-parse --show-toplevel)
cd "$PROJECT_DIR" || exit 1

echo "=== Pre-commit (mmchong-init lightweight) ==="

STAGED_FILES=$(git diff --cached --name-only)
if [ -z "$STAGED_FILES" ]; then
    echo "No staged files, skipping."
    exit 0
fi

# 0) apps/web 路径下禁止 emoji（本仓库无 apps/web 时通常无文件可扫，直接通过）
echo "[0] Web emoji check (apps/web only)..."
if [ -f scripts/check-web-no-emoji.mjs ]; then
    if ! node scripts/check-web-no-emoji.mjs --staged; then
        echo "Web emoji check failed."
        exit 1
    fi
fi
echo "OK"

# 1) 单文件行数（与 stop_verify / AGENTS 约定一致）
echo "[1] Line limits (ts/tsx/js/jsx/py)..."
ERRORS=""
for FILE in $STAGED_FILES; do
    case "$FILE" in
        *.ts|*.tsx|*.js|*.jsx|*.py)
            if [ -f "$FILE" ]; then
                LINES=$(wc -l < "$FILE")
                if [ "$LINES" -gt 500 ]; then
                    ERRORS="${ERRORS}${FILE}: ${LINES} lines (max 500)\n"
                fi
            fi
            ;;
    esac
done
if [ -n "$ERRORS" ]; then
    echo "$ERRORS"
    exit 1
fi
echo "OK"

# 2) 有代码/文档变更的目录需有 index.md（根目录除外）
echo "[2] index.md beside staged changes..."
ERRORS=""
INDEX_CHECK_FILES=$(git diff --cached --name-only --diff-filter=ACMRT)
for FILE in $INDEX_CHECK_FILES; do
    case "$FILE" in
        *.ts|*.tsx|*.js|*.jsx|*.py|*.md)
            DIR=$(dirname "$FILE")
            if [ "$DIR" = "." ]; then
                continue
            fi
            if [ ! -f "$DIR/index.md" ]; then
                ERRORS="${ERRORS}Missing ${DIR}/index.md (staged: ${FILE})\n"
            fi
            ;;
    esac
done
if [ -n "$ERRORS" ]; then
    echo "$ERRORS"
    exit 1
fi
echo "OK"

echo "=== Pre-commit passed ==="
exit 0
