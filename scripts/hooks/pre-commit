#!/bin/sh
# 默认轻量 pre-commit：emoji（apps/web）、行数、index.md 旁路检查。
# 业务 monorepo 请按需追加：pnpm turbo build、lint、lint-deps、test 等。

PROJECT_DIR=$(git rev-parse --show-toplevel)
cd "$PROJECT_DIR" || exit 1

echo "=== Pre-commit (lightweight default) ==="

STAGED_FILES=$(git diff --cached --name-only)
if [ -z "$STAGED_FILES" ]; then
    echo "No staged files, skipping."
    exit 0
fi

echo "[0] Web emoji check (apps/web only)..."
if [ -f scripts/check-web-no-emoji.mjs ]; then
    if ! node scripts/check-web-no-emoji.mjs --staged; then
        echo "Web emoji check failed."
        exit 1
    fi
fi
echo "OK"

echo "[1] Line limits (ts/tsx/js/jsx/py)..."
ERRORS=""
for FILE in $STAGED_FILES; do
    case "$FILE" in
        *.ts|*.tsx|*.js|*.jsx|*.py)
            if [ -f "$FILE" ]; then
                LINES=$(wc -l < "$FILE")
                if [ "$LINES" -gt 500 ]; then
                    ERRORS="${ERRORS}${FILE}: ${LINES} lines (max 500)\n"
                fi
            fi
            ;;
    esac
done
if [ -n "$ERRORS" ]; then
    echo "$ERRORS"
    exit 1
fi
echo "OK"

echo "[2] index.md beside staged changes..."
ERRORS=""
INDEX_CHECK_FILES=$(git diff --cached --name-only --diff-filter=ACMRT)
for FILE in $INDEX_CHECK_FILES; do
    case "$FILE" in
        *.ts|*.tsx|*.js|*.jsx|*.py|*.md)
            DIR=$(dirname "$FILE")
            if [ "$DIR" = "." ]; then
                continue
            fi
            if [ ! -f "$DIR/index.md" ]; then
                ERRORS="${ERRORS}Missing ${DIR}/index.md (staged: ${FILE})\n"
            fi
            ;;
    esac
done
if [ -n "$ERRORS" ]; then
    echo "$ERRORS"
    exit 1
fi
echo "OK"

echo "=== Pre-commit passed ==="
exit 0
